# Copy to .env.local for local dev or .env.prod for production.
# NIM_ENV controls which file the server loads (local|prod).

PORT=8080
LOCAL_DEV=true|false

# Postgres connection string
DATABASE_URL=host=... user=... password=... dbname=... port=5432 sslmode=disable|require

# AWS / S3
AWS_REGION=us-east-1
S3_BUCKET=
S3_ENDPOINT=             # local only: http://localhost:4566
S3_FORCE_PATH_STYLE=     # local only: true

# Auth
JWT_SECRET=

# Client (set in shell, not a server env var)
# NIM_ENV=local|prod
# NIM_API_URL=https://your-alb-url   (required when NIM_ENV=prod)
